{
  "name": "jitty",
  "version": "0.1.0",
  "type": "module",
  "description": "Just-In-Time TypeScript Transpile Execution: Run TypeScript ESM in Node.js CLI",
  "keywords": [
    "cli",
    "runtime",
    "node",
    "esm",
    "typescript",
    "typescript runner"
  ],
  "author": "Refirst",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/refirst11/jitt.git"
  },
  "license": "MIT",
  "main": "dist/esm-register.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rimraf dist && npx tsc && pnpm minify",
    "minify": "terser dist/jitty.js -c -o dist/jitty.js"
  },
  "dependencies": {
    "@swc/core": "^1.11.24"
  },
  "devDependencies": {
    "@types/node": "^22.13.17",
    "rimraf": "^6.0.1",
    "terser": "^5.39.0",
    "typescript": "^5.8.2"
  }
}
